# ── Model ─────────────────────────────────────────────────────────────────────
MODEL_PATH=models/weights/yolov8s_traffic.onnx
CONFIDENCE_THRESHOLD=0.4
IOU_THRESHOLD=0.5
# Classes to detect (COCO indices: 2=car, 3=motorcycle, 5=bus, 7=truck)
TARGET_CLASSES=2,3,5,7

# ── Video Source ──────────────────────────────────────────────────────────────
# Options: path to file, 0 for webcam, rtsp://... for RTSP stream
VIDEO_SOURCE=data/sample_videos/traffic.mp4
# Max frames per second to process (use 0 for unlimited)
TARGET_FPS=25
# Process every Nth frame (1 = every frame, 2 = every other frame, etc.)
FRAME_SKIP=1

# ── Analytics ─────────────────────────────────────────────────────────────────
# Speed calibration: meters per pixel at the camera's focal plane (estimate)
METERS_PER_PIXEL=0.05
# Anomaly detection: rolling window size (seconds) for baseline
ANOMALY_WINDOW_SECONDS=60
# Anomaly threshold: standard deviations above mean to trigger alert
ANOMALY_STD_THRESHOLD=2.0

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Storage ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./trafficvision.db
DATABASE_PATH=data/traffic.db
# In-memory ring buffer duration (seconds)
RING_BUFFER_SECONDS=300

# ── WebSocket ─────────────────────────────────────────────────────────────────
# JPEG quality for video stream (1-100)
JPEG_QUALITY=80
# Metrics broadcast interval (milliseconds)
METRICS_INTERVAL_MS=500
